#!/usr/bin/env python3
# {{ ansible_managed }}
"""labforge log viewer — a tiny, dependency-free, Splunk-style log browser.

Serves a read-only web UI over the per-host log files that the rsyslog central
collector writes under LOG_ROOT/<host>/messages.log. Uses ONLY the Python
standard library so it runs on any lab box with python3 and needs no internet.

Endpoints
---------
  GET /                       host list + recent-events dashboard
  GET /host/<name>            last N lines for one host
  GET /search?q=<term>        grep across every host's logs
  GET /api/hosts              JSON list of hosts + line counts
  GET /api/tail/<name>?n=200  JSON tail of a host's log

This is deliberately simple and safe: it never writes, and every path is
validated against the known host directories to prevent traversal.
"""
from __future__ import annotations

import html
import json
import os
import re
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from urllib.parse import urlparse, parse_qs

LOG_ROOT = "{{ splunk_log_root }}"
PORT = {{ splunk_web_port }}
DEFAULT_TAIL = 300
HOST_RE = re.compile(r"^[A-Za-z0-9_.-]+$")


def list_hosts() -> list[dict]:
    """Return [{name, lines, bytes}] for every host directory with a log."""
    hosts = []
    if not os.path.isdir(LOG_ROOT):
        return hosts
    for name in sorted(os.listdir(LOG_ROOT)):
        path = os.path.join(LOG_ROOT, name, "messages.log")
        if os.path.isfile(path):
            try:
                size = os.path.getsize(path)
                with open(path, "rb") as fh:
                    lines = sum(1 for _ in fh)
            except OSError:
                size, lines = 0, 0
            hosts.append({"name": name, "lines": lines, "bytes": size})
    return hosts


def safe_host_path(name: str) -> str | None:
    """Resolve a host name to its log path, refusing anything unexpected."""
    if not HOST_RE.match(name):
        return None
    path = os.path.normpath(os.path.join(LOG_ROOT, name, "messages.log"))
    if not path.startswith(os.path.abspath(LOG_ROOT)):
        return None
    return path if os.path.isfile(path) else None


def tail(path: str, n: int) -> list[str]:
    """Return the last n lines of a file without loading the whole thing."""
    try:
        with open(path, "rb") as fh:
            fh.seek(0, os.SEEK_END)
            end = fh.tell()
            block = 4096
            data = b""
            while end > 0 and data.count(b"\n") <= n:
                step = min(block, end)
                end -= step
                fh.seek(end)
                data = fh.read(step) + data
        text = data.decode("utf-8", "replace")
        return text.splitlines()[-n:]
    except OSError:
        return []


def search_all(term: str, limit: int = 500) -> list[tuple[str, str]]:
    """Case-insensitive grep across every host log. Returns (host, line)."""
    results: list[tuple[str, str]] = []
    needle = term.lower()
    for host in list_hosts():
        path = os.path.join(LOG_ROOT, host["name"], "messages.log")
        try:
            with open(path, "r", encoding="utf-8", errors="replace") as fh:
                for line in fh:
                    if needle in line.lower():
                        results.append((host["name"], line.rstrip("\n")))
                        if len(results) >= limit:
                            return results
        except OSError:
            continue
    return results


PAGE_CSS = """
